---
---

<section class="section" style="background:var(--background-tan)" aria-label="商品紹介">
  <div class="screen-wrapper">
    <div class="product screen">
      <div class="product__inner">
        <img class="product__photo" src="/mca-allergencut/img/adobestock-292120451-2.webp" alt="犬の写真" />
        <div class="product__card" aria-hidden="true"></div>
        <h2 class="product__name product__name--left">魚 ＆ お米</h2>
        <h2 class="product__name product__name--right">魚 ＆えんどう豆たんぱく</h2>
        <img class="product__package product__package--left" src="/mca-allergencut/img/u0311-1.webp" alt="魚＆お米 2.5kg パッケージ" />
        <img class="product__package product__package--right" src="/mca-allergencut/img/u0311-2.webp" alt="魚＆えんどう豆たんぱく 2kg パッケージ" />
        <p class="product__brand">メディコートアドバンス<br />アレルゲンカット</p>
        <div class="product__underline" aria-hidden="true"></div>
        <img class="product__gf-icon" src="/mca-allergencut/img/gf-c-f-2.webp" alt="ドライフードの粒" />

        <div class="product__heading">
          <div class="product__heading-group">
            <div class="product__heading-lines">
              <p class="product__heading-line product__heading-line--top">毎日のごはんだから、</p>
              <p class="product__heading-line product__heading-line--bottom">たんぱく源で選ぶ</p>
            </div>
            <img class="product__heading-deco product__heading-deco--inner" src="/mca-allergencut/img/group-5.webp" alt="" aria-hidden="true" />
          </div>
          <img class="product__heading-deco product__heading-deco--outer" src="/mca-allergencut/img/group-5-1.webp" alt="" aria-hidden="true" />
        </div>

        <div class="product__cta" id="cta">
          <div class="product__cta-badge">
            <div class="product__cta-badge-text">お一人様1回限りの限定価格</div>
          </div>
          <p class="product__cta-price">しっかり試せてどちらも800円</p>
          <a class="product__cta-button" href="#footer-cta" aria-label="今すぐ試す">
            <div class="product__cta-button-bg" aria-hidden="true"></div>
            <img class="product__cta-button-arrow" src="/mca-allergencut/img/vector-1-6.svg" alt="" aria-hidden="true" />
            <div class="product__cta-button-text">今すぐ試す</div>
          </a>
          <p class="product__cta-micro">お届けは1回のみ。自動継続なし。</p>
        </div>

        <img class="product__weight product__weight--left" src="/mca-allergencut/img/badge-2_5kg.webp" alt="2.5kg" />
        <img class="product__weight product__weight--right" src="/mca-allergencut/img/badge-2kg.webp" alt="2kg" />
      </div>
    </div>
  </div>
</section>

<style>
  .product {
    position: relative;
    width: 440px;
    height: 959px;
    background-color: var(--background-tan);
    overflow: hidden;
  }

  .product__inner {
    position: relative;
    top: 37px;
    left: 24px;
    width: 402px;
    height: 780px;
    /* フッター上の領域で上下を均等化（上に詰める） */
    transform: translateY(-11px);
  }

  .product__photo {
    position: absolute;
    top: 83px;
    left: 133px;
    width: 117px;
    height: 151px;
    object-fit: cover;
  }

  .product__card {
    position: absolute;
    top: 204px;
    left: calc(50% - 201px);
    width: 393px;
    height: 562px;
    background-color: var(--white);
    border-radius: 10px;
    box-shadow: 3px 3px 5px var(--shadow-soft);
  }

  .product__name {
    position: absolute;
    top: 360px;
    width: 165px;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--amber-brown);
    font-size: var(--font-size-s);
    text-align: center;
    letter-spacing: 0;
    line-height: 18.2px;
  }

  .product__name--left {
    left: 22px;
  }

  .product__name--right {
    left: 209px;
  }

  .product__package {
    position: absolute;
    width: 110px;
    height: 197px;
    object-fit: contain;
  }

  .product__package--left {
    top: 388px;
    left: 50px;
  }

  .product__package--right {
    top: 387px;
    left: 237px;
  }

  .product__brand {
