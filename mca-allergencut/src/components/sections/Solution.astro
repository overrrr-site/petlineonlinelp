    font-family: var(--font-family);
    font-weight: 900;
    color: var(--green-vivid);
    font-size: var(--font-size-product-brand);
    text-align: center;
    letter-spacing: -1.25px;
    line-height: 32px;
  }

  .product__underline {
    position: absolute;
    top: 299px;
    left: calc(50% - 165px);
    width: 282px;
    height: 38px;
    background-image: url(/mca-allergencut/img/vector-11.svg);
    background-size: 100% 100%;
  }

  .product__gf-icon {
    position: absolute;
    top: 255px;
    left: 306px;
    width: 73px;
    height: 50px;
