    left: 27px;
  }

  .product__heading-group {
    position: absolute;
    width: 337px;
    height: 73px;
    top: 0;
    left: 0;
  }

  .product__heading-lines {
    position: absolute;
    top: 0;
    left: 44px;
    width: 255px;
    height: 72px;
    display: flex;
    flex-direction: column;
  }

  .product__heading-line {
    width: 251px;
    height: 36px;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--white);
    font-size: var(--font-size-heading-line);
    letter-spacing: 0;
    line-height: 36px;
    white-space: nowrap;
  }

  .product__heading-line--bottom {
    margin-left: 25px;
