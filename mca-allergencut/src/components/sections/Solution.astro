    width: 241px;
    height: 141px;
  }

  .product__cta-badge {
    display: flex;
    width: 69.71%;
    height: 18.44%;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 1px 12px;
    position: absolute;
    top: 0;
    left: 15.15%;
    border: 1px solid;
    border-color: var(--orange);
  }

  .product__cta-badge-text {
    position: relative;
    width: fit-content;
    margin-left: -2px;
    margin-right: -2px;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--orange);
    font-size: var(--font-size-xs);
    letter-spacing: -0.12px;
    line-height: 18px;
    white-space: nowrap;
  }

  .product__cta-price {
    position: absolute;
    width: 100%;
    height: 16.31%;
    top: 24.11%;
    left: 0;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--text-dark);
    font-size: var(--font-size-l);
    text-align: center;
    letter-spacing: 0.8px;
    line-height: normal;
  }

  .product__cta-button {
    position: absolute;
    width: 243px;
    height: 56px;
    top: 65px;
    left: 0;
  }

  .product__cta-button-bg {
    width: 99.18%;
    background-color: var(--orange);
    border-radius: 999px;
    box-shadow: 0px 4px 4px var(--shadow-strong);
    overflow: hidden;
    position: absolute;
    height: 100%;
    top: 0;
    left: 0;
    animation: cta-glow 2s ease-in-out infinite;
  }

  .product__cta-button-bg::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent 0%, rgba(var(--white-rgb), 0.25) 50%, transparent 100%);
    animation: cta-shine 3s ease-in-out infinite;
    pointer-events: none;
  }

  .product__cta-button-arrow {
    position: absolute;
    width: 7.5%;
    height: 34%;
