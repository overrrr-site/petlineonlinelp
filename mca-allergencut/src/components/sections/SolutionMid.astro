---
---

<section class="section" aria-labelledby="type-title">
  <div class="screen-wrapper">
    <div class="type screen">
      <div class="type__inner">
        <div class="type__header">
          <div class="type__title-wrapper">
            <div class="type__title-block">
              <div class="type__heading">
                <p class="type__label">あなたの愛犬には、どっち？</p>
                <div class="type__title-row">
                  <h2 class="type__title" id="type-title">愛犬に合わせて、<br/>2タイプから。</h2>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="type__card-area--rice">
          <article class="type__option--rice">
            <div class="type__option-body">
              <div class="type__option-figure">
                <div class="type__option-figure-inner">
                  <img class="type__option-package" src="/mca-allergencut/img/u0311-3-1.png" alt="魚＆お米 2.5kg パッケージ" />
                </div>
              </div>
              <div class="type__option-text">
                <p class="type__option-name"><span class="type__option-name-main">魚＆お米</span><span class="type__option-name-space">&nbsp;</span><span class="type__option-name-weight">2.5kg</span></p>
                <p class="type__option-axis">まずはアレルゲン配慮から<br/>始めたい愛犬へ</p>
                <p class="type__option-desc">お米入りの標準設計。DHA・EPA／亜鉛アミノ酸複合体で皮膚・被毛の健康維持に貢献。</p>
              </div>
            </div>
          </article>
          <div class="type__pick-badge"><div class="type__pick-badge-text">迷ったらこちら</div></div>
        </div>

        <div class="type__card-area--pea">
          <article class="type__option--pea">
            <div class="type__option-body">
              <div class="type__option-figure">
                <div class="type__option-figure-inner">
                  <img class="type__option-package" src="/mca-allergencut/img/u0311-3-4.png" alt="魚＆えんどう豆たんぱく 2kg パッケージ" />
                </div>
              </div>
              <div class="type__option-text">
                <p class="type__option-name--pea"><span class="type__option-name-main">魚&amp;えんどう豆<br/>たんぱく </span><span class="type__option-name-weight">2kg</span></p>
                <p class="type__option-axis">お米を避けたい愛犬へ</p>
                <p class="type__option-desc">DHA・EPA／亜鉛アミノ酸複合体で皮膚・被毛の健康維持に貢献。</p>
              </div>
            </div>
          </article>

          <a class="type__cta" href="#footer-cta" aria-label="今すぐ試す">
            <div class="type__cta-badge">
              <div class="type__cta-badge-text">お一人様1回限りの限定価格</div>
              <img class="type__cta-badge-line" src="/mca-allergencut/img/vector-4-2.svg" alt="" aria-hidden="true" />
            </div>

            <img class="type__cta-price-img" src="/mca-allergencut/img/fv-price.png" alt="2kg / 2.5kg が 800円" />

            <div class="type__cta-button">
              <div class="type__cta-button-bg" aria-hidden="true"></div>
              <img class="type__cta-button-arrow" src="/mca-allergencut/img/vector-1-5.svg" alt="" aria-hidden="true" />
              <div class="type__cta-button-text">今すぐ試す</div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .type {
    position: relative;
    width: 440px;
    height: 959px;
    background-color: var(--background-02);
    overflow: hidden;
  }

  .type__inner {
    display: flex;
    flex-direction: column;
    width: 380px;
    align-items: center;
    justify-content: center;
    gap: 22px;
    position: relative;
    top: 64px;
    left: 24px;
  }

  .type__header {
    display: flex;
    flex-direction: column;
    width: 350px;
    align-items: center;
    justify-content: center;
    gap: 24px;
    position: relative;
    flex: 0 0 auto;
  }

  .type__title-wrapper {
    position: relative;
    width: 350px;
    height: 124px;
  }

  .type__title-block {
    display: flex;
    flex-direction: column;
    width: 100%;
    align-items: center;
    gap: 16px;
    position: relative;
  }

  .type__heading {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    position: relative;
    align-self: stretch;
    width: 100%;
    flex: 0 0 auto;
  }

  .type__label {
    position: relative;
    align-self: stretch;
    margin-top: -1px;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--green-vivid);
    font-size: var(--font-size-s);
    text-align: center;
    letter-spacing: 1px;
    line-height: 22px;
  }

  .type__title-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    position: relative;
    align-self: stretch;
    width: 100%;
    flex: 0 0 auto;
  }

  .type__title {
    position: relative;
    width: fit-content;
    margin-top: -1px;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--brown-title-text);
    font-size: var(--font-size-title-m);
    text-align: center;
    letter-spacing: 1.5px;
    line-height: normal;
  }

  /* Card area: rice */
  .type__card-area--rice {
    position: relative;
    width: 380px;
    height: 180px;
  }

  .type__option--rice {
    display: inline-flex;
    height: 168px;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 2px 11px;
    position: absolute;
    top: 12px;
    left: 0;
    width: 380px;
    box-sizing: border-box;
    background-color: var(--white);
    border-radius: 10px;
    border: 2px solid;
    border-color: var(--green-vivid);
    box-shadow: 3px 3px 5px var(--shadow-soft);
  }

  /* Card area: pea */
  .type__card-area--pea {
    position: relative;
    width: 380px;
    height: 233px;
  }

  .type__option--pea {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
    gap: 10px;
    position: relative;
    width: 380px;
    box-sizing: border-box;
    background-color: var(--white);
    border-radius: 10px;
    border: 2px solid;
    border-color: var(--green-vivid);
    box-shadow: 3px 3px 5px var(--shadow-soft);
  }

  /* Shared card internals */
  .type__option-body {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    position: relative;
    flex: 0 0 auto;
  }

  .type__option-figure {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    position: relative;
    flex: 0 0 auto;
  }

  .type__option-figure-inner {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px;
    position: relative;
    flex: 0 0 auto;
  }

  .type__option-package {
    position: relative;
    width: 72px;
    height: 128px;
    object-fit: contain;
  }

  .type__option-text {
    display: flex;
    flex-direction: column;
    width: 240px;
    align-items: flex-start;
    gap: 4px;
    position: relative;
  }

  /* Product name (shared base; line-height differs per variant) */
  .type__option-name,
  .type__option-name--pea {
    width: 240px;
    font-weight: 400;
    position: relative;
    margin-top: -1px;
    font-family: var(--font-family);
    color: var(--amber-brown);
    font-size: var(--font-size-product-title);
    letter-spacing: 1.2px;
  }

  .type__option-name {
    line-height: 24px;
  }

  .type__option-name--pea {
    line-height: 28px;
  }

  .type__option-name-main {
    font-weight: 700;
    letter-spacing: 1px;
    line-height: 24px;
    font-family: var(--font-family);
    font-size: var(--font-size-subheading);
  }

  .type__option-name-space {
    font-weight: 700;
    letter-spacing: 0.29px;
  }

  .type__option-name-weight {
    font-weight: 500;
    font-size: var(--font-size-s);
    letter-spacing: 0.1px;
    line-height: 21px;
  }

  .type__option-axis {
    position: relative;
    align-self: stretch;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--green-vivid);
    font-size: var(--font-size-m);
    letter-spacing: 0.75px;
    line-height: normal;
  }

  .type__option-desc {
    position: relative;
    align-self: stretch;
    font-family: var(--font-family);
    font-weight: 500;
    color: var(--text-dark);
    font-size: var(--font-size-xs);
    letter-spacing: 0;
    line-height: 19.2px;
  }

  /* Age tags */
  .type__tags {
    display: flex;
    height: 19px;
    align-items: center;
    gap: 4px;
    position: relative;
    align-self: stretch;
    width: 100%;
  }

  .type__tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 3px 13px;
    position: relative;
    flex: 0 0 auto;
    border-radius: 59.79px;
    border: 1.2px solid;
    border-color: var(--green-vivid);
  }

  /* Tag label text (shared typography across all tag widths) */
  .type__tag-text,
  .type__tag-text--wide,
  .type__tag-text--xwide {
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--green-vivid);
    font-size: var(--font-size-age-tag);
    text-align: center;
    letter-spacing: 0;
    line-height: 12.4px;
    white-space: nowrap;
  }

  .type__tag-text {
    position: relative;
    width: fit-content;
    margin-top: -1.2px;
  }

  .type__tag-wrapper {
    position: relative;
    width: 56px;
    height: 19px;
  }

  .type__tag--wide {
    width: 56px;
    height: 19px;
    display: flex;
    border-radius: 59.79px;
    border: 1.2px solid;
    border-color: var(--green-vivid);
  }

  .type__tag-text--wide {
    margin-top: 3px;
    width: 30px;
    height: 13px;
    margin-left: 13px;
  }

  .type__tag-group {
    position: relative;
    width: 70px;
    height: 19px;
  }

  .type__tag--xwide {
    width: 70px;
    height: 19px;
    display: flex;
    border-radius: 59.79px;
    border: 1.2px solid;
    border-color: var(--green-vivid);
  }

  .type__tag-inner {
    margin-top: 3px;
    width: 41px;
    margin-left: 15px;
    display: flex;
  }

  .type__tag-text--xwide {
    width: 39px;
    height: 13px;
  }

  /* "迷ったらこちら" badge */
  .type__pick-badge {
    position: absolute;
    top: 0;
    left: 8px;
    width: 156px;
    height: 25px;
    background-color: var(--green-vivid);
    border-radius: 100px;
  }

  .type__pick-badge-text {
    position: absolute;
    width: 80.14%;
    height: 85.71%;
    top: 0;
    left: 9.62%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-family);
    font-weight: 500;
    color: var(--white);
    font-size: var(--font-size-l);
    text-align: center;
    letter-spacing: 0.8px;
    line-height: 24px;
    white-space: nowrap;
  }

  /* CTA block */
  .type__cta {
    position: relative;
    display: block;
    width: 335.44px;
    height: 153.92px;
    margin: 18px auto 0;
  }

  .type__cta-badge {
    position: absolute;
    width: 61.72%;
    height: 21.01%;
    top: 0;
    left: 19.38%;
  }

  .type__cta-badge-text {
    position: absolute;
    width: 96.13%;
    height: 74.22%;
    top: 0;
    left: 0;
    transform: rotate(-0.1deg);
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--amber-brown);
    font-size: var(--font-size-m);
    letter-spacing: 0.62px;
    line-height: 23.1px;
    white-space: nowrap;
  }

  .type__cta-badge-line {
    position: absolute;
    width: 150%;
    height: 26.29%;
    top: 73.71%;
    left: -7%;
  }

  /* 価格表示：FVと同じ単一画像に差し替え（旧・多重SVG構成を撤去） */
  .type__cta-price-img {
    position: absolute;
    width: 335px;
    height: auto;
    top: 36px;
    left: 0;
  }

  .type__cta-button {
    position: absolute;
    width: 247px;
    height: 56px;
    top: 97px;
    left: 45px;
  }

  .type__cta-button-bg {
    position: absolute;
    width: 99.19%;
    height: 100%;
    top: 0;
    left: 0;
    background-color: var(--orange);
    border-radius: 999px;
    box-shadow: 0px 4px 4px var(--shadow-strong);
    overflow: hidden;
    animation: cta-glow 2s ease-in-out infinite;
  }

  .type__cta-button-bg::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent 0%, rgba(var(--white-rgb), 0.25) 50%, transparent 100%);
    animation: cta-shine 3s ease-in-out infinite;
    pointer-events: none;
  }

  .type__cta-button-arrow {
    position: absolute;
    width: 7.5%;
    height: 34%;
    top: 33%;
    left: 71.5%;
    object-fit: contain;
  }

  .type__cta-button-text {
    position: absolute;
    width: 46.15%;
    height: 56.21%;
    top: 17.57%;
    left: 22.67%;
    font-family: var(--font-family);
    font-weight: 900;
    color: var(--white);
    font-size: var(--font-size-cta);
    letter-spacing: 1.09px;
    line-height: normal;
  }

</style>
