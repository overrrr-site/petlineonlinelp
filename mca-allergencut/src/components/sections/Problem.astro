---
---

<section class="section" aria-labelledby="allergen-title">
  <div class="screen-wrapper">
    <div class="allergen screen">
      <div class="allergen__inner">
        <div class="allergen__header">
          <div class="allergen__intro">
            <div class="allergen__badge">
              <div class="allergen__badge-text">実は</div>
              <div class="allergen__badge-frame" aria-hidden="true"></div>
            </div>
            <div class="allergen__title-wrapper">
              <h2 class="allergen__title" id="allergen-title">食物アレルゲンの正体は、<br />フードに含まれる<br />「たんぱく源」でした。</h2>
            </div>
            <div class="allergen__desc-wrapper">
              <p class="allergen__desc">愛犬の食物アレルゲンの多くは、ドッグフードに含まれるたんぱく源に由来すると言われています。</p>
            </div>
          </div>

          <div class="allergen__compare">
            <div class="allergen__panel allergen__panel--common">
              <div class="allergen__panel-box" aria-hidden="true"></div>
              <p class="allergen__panel-heading">よく使われるたんぱく源</p>
              <div class="allergen__panel-tag" aria-hidden="true"></div>
              <div class="allergen__panel-tag-text">一般的なフード</div>
              <div class="allergen__grid">
                <div class="allergen__cell allergen__cell--r0c0">
                  <div class="allergen__cell-text">鶏肉</div>
                  <div class="allergen__cell-box" aria-hidden="true"></div>
                </div>
                <div class="allergen__cell allergen__cell--r1c0">
                  <div class="allergen__cell-text allergen__cell-text--wide">乳製品</div>
                  <div class="allergen__cell-box" aria-hidden="true"></div>
                </div>
                <div class="allergen__cell allergen__cell--r0c1">
                  <div class="allergen__cell-text">小麦</div>
                  <div class="allergen__cell-box" aria-hidden="true"></div>
                </div>
                <div class="allergen__cell allergen__cell--r0c2">
                  <div class="allergen__cell-text">牛肉</div>
                  <div class="allergen__cell-box" aria-hidden="true"></div>
                </div>
                <div class="allergen__cell allergen__cell--r1c2">
                  <div class="allergen__cell-text">大豆</div>
                  <div class="allergen__cell-box" aria-hidden="true"></div>
                </div>
                <div class="allergen__cell allergen__cell--r0c3">
                  <div class="allergen__cell-text">豚肉</div>
                  <div class="allergen__cell-box" aria-hidden="true"></div>
                </div>
                <div class="allergen__cell allergen__cell--r1c3">
                  <div class="allergen__cell-text">鶏卵</div>
                  <div class="allergen__cell-box" aria-hidden="true"></div>
                </div>
              </div>
            </div>

            <div class="allergen__arrow" aria-hidden="true"><div class="allergen__arrow-icon"></div></div>

            <div class="allergen__panel allergen__panel--cut">
              <div class="allergen__cut">
                <div class="allergen__cut-box" aria-hidden="true"></div>
                <div class="allergen__cut-headline">
                  <div class="allergen__cut-lead">主なたんぱく源を</div>
                  <div class="allergen__cut-suffix">に限定</div>
                  <div class="allergen__cut-number">2</div>
                  <div class="allergen__cut-unit">種類</div>
                </div>
                <div class="allergen__cut-tag">
                  <div class="allergen__cut-tag-bg" aria-hidden="true"></div>
                  <div class="allergen__cut-tag-text">アレルゲンカットは</div>
                </div>
              </div>
              <div class="allergen__cut-item allergen__cut-item--left">
                <div class="allergen__cut-item-box" aria-hidden="true"></div>
                <div class="allergen__cut-item-text">魚 ＆ お米</div>
              </div>
              <div class="allergen__cut-item allergen__cut-item--right">
                <div class="allergen__cut-item-box" aria-hidden="true"></div>
                <div class="allergen__cut-item-text allergen__cut-item-text--wide">魚 ＆えんどう豆たんぱく</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <img class="allergen__pug" src="/mca-allergencut/img/allergen-pug.webp" alt="" aria-hidden="true" loading="lazy" />
    </div>
  </div>
</section>

<style>
  .allergen {
    position: relative;
    width: 440px;
    height: 959px;
    background-color: var(--background-02);
    overflow: hidden;
  }

  /* 装飾：セクション最下部中央に座るパグ（フッター上の空きスペース） */
  .allergen__pug {
    position: absolute;
    left: calc(50% - 48px);
    bottom: 96px;
    width: 96px;
    height: auto;
    z-index: 2;
    pointer-events: none;
  }

  .allergen__inner {
    display: flex;
    flex-direction: column;
    width: 405px;
    align-items: center;
    justify-content: center;
    gap: 24px;
    position: relative;
    top: 84px;
    left: calc(50% - 203px);
  }

  .allergen__header {
    display: flex;
    flex-direction: column;
    width: 350px;
    align-items: center;
    gap: 24px;
    position: relative;
    flex: 0 0 auto;
  }

  .allergen__intro {
    display: flex;
    flex-direction: column;
    width: 350px;
    align-items: center;
    gap: 16px;
    position: relative;
    flex: 0 0 auto;
  }

  /* "実は" badge */
  .allergen__badge {
    position: relative;
    width: 61px;
    height: 28px;
  }

  .allergen__badge-text {
    position: absolute;
    top: 2px;
    left: 15px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0;
    line-height: normal;
    white-space: nowrap;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--green-vivid);
    font-size: var(--font-size-s);
    text-align: center;
  }

  .allergen__badge-frame {
    position: absolute;
    top: 0;
    left: calc(50% - 30px);
    width: 59px;
    height: 28px;
    border-radius: 100px;
    border: 1px solid;
    border-color: var(--green-vivid);
  }

  /* Title */
  .allergen__title-wrapper {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    position: relative;
    flex: 0 0 auto;
    margin-left: -13.5px;
    margin-right: -13.5px;
  }

  .allergen__title {
    width: 377px;
    position: relative;
    margin-top: -1px;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--green-vivid);
    font-size: var(--font-size-title-s);
    text-align: center;
    letter-spacing: 0.8px;
    line-height: 1.35;
  }

  /* Description */
  .allergen__desc-wrapper {
    display: flex;
    width: 350px;
    align-items: center;
    justify-content: center;
    gap: 10px;
    position: relative;
    flex: 0 0 auto;
  }

  .allergen__desc {
    position: relative;
    width: 371px;
    margin-top: -1px;
    margin-left: -10.5px;
    margin-right: -10.5px;
    font-weight: 500;
    color: var(--text-dark);
    font-size: var(--font-size-s);
    letter-spacing: 0;
    line-height: 24px;
    font-family: var(--font-family);
    text-align: center;
  }

  /* Compare block (common panel + arrow + cut panel) */
  .allergen__compare {
    display: flex;
    flex-direction: column;
    width: 379px;
    align-items: center;
    justify-content: center;
    gap: 15px;
    position: relative;
    flex: 0 0 auto;
    margin-left: -14.5px;
    margin-right: -14.5px;
  }

  /* Common protein-source panel */
  .allergen__panel--common {
    position: relative;
    width: 382px;
    height: 191px;
    margin-right: -3.5px;
  }

  .allergen__panel-box {
    position: absolute;
    top: 13px;
    left: 0;
    width: 378px;
    height: 178px;
    background-color: var(--white);
    border-radius: 8px;
    border: 2px solid;
    border-color: var(--text-author);
  }

  .allergen__panel-heading {
    top: 41px;
    left: 79px;
    width: 222px;
    color: var(--text-dark);
    font-size: var(--font-size-subheading);
    line-height: 16.5px;
    position: absolute;
    font-family: var(--font-family);
    font-weight: 700;
    text-align: center;
    letter-spacing: 0;
  }

  .allergen__panel-tag {
    position: absolute;
    top: 0;
    left: 13px;
    width: 127px;
    height: 25px;
    background-color: var(--text-author);
    border-radius: 500px;
  }

  .allergen__panel-tag-text {
    position: absolute;
    top: 4px;
    left: 26px;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--white);
    font-size: var(--font-size-s);
    letter-spacing: 0;
    line-height: 17.6px;
    white-space: nowrap;
  }

  /* Grid of protein cells */
  .allergen__grid {
    position: absolute;
    top: 74px;
    left: 26px;
    width: 336px;
    height: 89px;
  }

  .allergen__cell {
    position: absolute;
    width: 81px;
    height: 43px;
  }

  .allergen__cell--r0c0 { top: 0; left: 0; }
  .allergen__cell--r0c1 { top: 0; left: 85px; }
  .allergen__cell--r0c2 { top: 0; left: 170px; }
  .allergen__cell--r0c3 { top: 0; left: 255px; }
  /* 下段は3セル（とうもろこしを削除）→ 上段4セルに対して中央寄せで配置 */
  .allergen__cell--r1c0 { top: 46px; left: 43px; }
  .allergen__cell--r1c2 { top: 46px; left: 128px; }
  .allergen__cell--r1c3 { top: 46px; left: 213px; }

  .allergen__cell-text {
    position: absolute;
    width: 32.1%;
    height: 48.84%;
    top: 25.58%;
    left: 34.16%;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--amber-brown);
    font-size: var(--font-size-cell);
    text-align: center;
    letter-spacing: 0;
    line-height: 20.8px;
    white-space: nowrap;
  }

  .allergen__cell-text--wide {
    width: 48.15%;
    left: 26.75%;
  }

  .allergen__cell-text--widest {
    width: 81.48%;
    left: 9.46%;
    font-size: var(--font-size-xs);
  }

  .allergen__cell-box {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    border-radius: 8px;
    border: 2px solid;
    border-color: var(--amber-brown);
  }

  /* 「使っていない」表現：各たんぱく源セルに斜線を引く */
  .allergen__cell-box::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 8px;
    background-image: linear-gradient(
      to top right,
      transparent calc(50% - 1.2px),
      var(--amber-brown) calc(50% - 1.2px),
      var(--amber-brown) calc(50% + 1.2px),
      transparent calc(50% + 1.2px)
    );
    pointer-events: none;
  }

  /* Down arrow between panels */
  .allergen__arrow {
    position: relative;
    width: 53px;
    height: 53px;
  }

  .allergen__arrow-icon {
    position: relative;
    width: 95.19%;
    height: 100%;
    left: 2.4%;
    background-image: url(/mca-allergencut/img/vector-10.svg);
    background-size: 100% 100%;
  }

  /* AllergenCut result panel */
  .allergen__panel--cut {
    position: relative;
    width: 378px;
    height: 153px;
  }

  .allergen__cut {
    position: absolute;
    top: 0;
    left: 0;
    width: 378px;
    height: 153px;
  }

  .allergen__cut-box {
    position: absolute;
    top: 12px;
    left: 0;
    width: 378px;
    height: 141px;
    background-color: var(--white);
    border-radius: 8px;
    border: 2px solid;
    border-color: var(--green-vivid);
  }

  .allergen__cut-headline {
    position: absolute;
    top: 33px;
    left: 65px;
    width: 280px;
    height: 41px;
  }

  .allergen__cut-lead {
    top: 7px;
    left: 0;
    width: 149px;
    color: var(--text-dark);
    font-size: var(--font-size-subheading);
    line-height: 27.4px;
    position: absolute;
    font-family: var(--font-family);
    font-weight: 700;
    text-align: center;
    letter-spacing: 0;
  }

  .allergen__cut-suffix {
    top: 6px;
    left: 217px;
    width: 55px;
    color: var(--text-dark);
    font-size: var(--font-size-subheading);
    line-height: 34.2px;
    position: absolute;
    font-family: var(--font-family);
    font-weight: 700;
    text-align: center;
    letter-spacing: 0;
  }

  .allergen__cut-number {
    top: 0;
    left: 147px;
    width: 26px;
    color: var(--green-vivid);
    font-size: var(--font-size-display-number);
    line-height: 34.2px;
    position: absolute;
    font-family: var(--font-family);
    font-weight: 700;
    text-align: center;
    letter-spacing: 0;
  }

  .allergen__cut-unit {
    top: 11px;
    left: 165px;
    width: 49px;
    color: var(--green-vivid);
    font-size: var(--font-size-display-unit);
    line-height: 20.5px;
    position: absolute;
    font-family: var(--font-family);
    font-weight: 700;
    text-align: center;
    letter-spacing: 0;
  }

  .allergen__cut-tag {
    position: absolute;
    top: 0;
    left: 13px;
    width: 155px;
    height: 25px;
  }

  .allergen__cut-tag-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 153px;
    height: 25px;
    background-color: var(--green-vivid);
    border-radius: 500px;
  }

  .allergen__cut-tag-text {
    position: absolute;
    top: 3px;
    left: 13px;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--white);
    font-size: var(--font-size-s);
    letter-spacing: 0;
    line-height: 17.6px;
    white-space: nowrap;
  }

  .allergen__cut-item {
    position: absolute;
    top: 81px;
    height: 57px;
  }

  .allergen__cut-item--left {
    left: 21px;
    width: 112px;
  }

  .allergen__cut-item--right {
    left: 135px;
    width: 225px;
  }

  .allergen__cut-item-box {
    position: absolute;
    top: 0;
    left: 0;
    height: 57px;
    border-radius: 8px;
    border: 2px solid;
    border-color: var(--amber-brown);
  }

  .allergen__cut-item--left .allergen__cut-item-box {
    width: 110px;
  }

  .allergen__cut-item--right .allergen__cut-item-box {
    width: 223px;
  }

  .allergen__cut-item-text {
    width: 100px;
    line-height: 20.8px;
    position: absolute;
    top: 17px;
    left: 5px;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--amber-brown);
    font-size: var(--font-size-l);
    text-align: center;
    letter-spacing: 0;
  }

  .allergen__cut-item-text--wide {
    width: 213px;
    line-height: 24px;
  }
</style>
