---
interface IngenuitySlide {
  image: string;
  imageAlt: string;
  imageClass?: string;
  heading: readonly string[];
  body: readonly string[];
}

const INGENUITY_SLIDES = [
  {
    image: '/mca-allergencut/img/ingenuity-kibble.webp',
    imageAlt: '小型犬でも食べやすい粒',
    heading: ['小型犬でも食べやすい', '粒の大きさ'],
    body: ['小さな口でも食べやすいよう、', '粒の大きさにこだわりました。', 'シニア犬にも好評です。'],
  },
  {
    image: '/mca-allergencut/img/ingenuity-pack.webp',
    imageAlt: '小分けパック',
    imageClass: 'ingenuity__card-image--pack',
    heading: ['500gの小分けパック'],
    body: ['500gずつの小分けパックで、', '開けたてのおいしさを', 'お届けします。'],
  },
  {
    image: '/mca-allergencut/img/image-1.webp',
    imageAlt: '総合栄養食のイメージ',
    imageClass: 'ingenuity__card-image--nutrition',
    heading: ['着色料不使用'],
    body: ['この製品は、ペットフード公正取引協議会の定める分析試験の結果、「総合栄養食」の基準を満たすことが証明されています。'],
  },
] satisfies readonly IngenuitySlide[];
---

<section class="section" style="background:var(--background-01)" aria-labelledby="ingenuity-title">
  <div class="screen-wrapper">
    <div
      class="ingenuity screen"
      id="feature-carousel"
      data-carousel-section="feature"
      role="group"
      aria-roledescription="カルーセル"
      aria-labelledby="ingenuity-title"
    >
      <div class="ingenuity__header">
        <div class="ingenuity__label">FEATURE</div>
        <h2 class="ingenuity__title" id="ingenuity-title">愛犬のための工夫</h2>
      </div>
      <p class="ingenuity__subtitle">毎日のごはんが、もっと食べやすく、<br />もっと続けやすく。<br />工夫を、たくさん詰め込みました。</p>
      <div class="ingenuity__bg-card ingenuity__bg-card--left"></div>
      <div class="ingenuity__bg-card ingenuity__bg-card--right"></div>
      <div class="ingenuity__slider">
        <button type="button" class="slider-btn slider-btn--prev" data-carousel="feature" aria-label="前へ" aria-controls="feature-carousel">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><circle cx="18" cy="18" r="18" fill="currentColor"/><path d="M20.5 12L15 17.5L20.5 23" stroke="var(--white)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="carousel-dots" data-carousel="feature" role="group" aria-label="スライド選択"></div>
        <button type="button" class="slider-btn slider-btn--next" data-carousel="feature" aria-label="次へ" aria-controls="feature-carousel">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none"><circle cx="18" cy="18" r="18" fill="currentColor"/><path d="M15.5 12L21 17.5L15.5 23" stroke="var(--white)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
      {INGENUITY_SLIDES.map((slide, index) => (
        <div
          class:list={['ingenuity__card', `main_${String(index + 1).padStart(2, '0')}`]}
          data-carousel-slide
          role="group"
          aria-roledescription="スライド"
          aria-label={`${index + 1} / ${INGENUITY_SLIDES.length}`}
          aria-hidden={index === 0 ? 'false' : 'true'}
        >
          <div class="ingenuity__card-inner">
            <img class:list={['ingenuity__card-image', slide.imageClass]} src={slide.image} alt={slide.imageAlt} loading="lazy" />
            <div class="ingenuity__card-content">
              <div class="ingenuity__card-heading">
                {slide.heading.map((line, lineIndex) => (
                  <Fragment>{line}{lineIndex < slide.heading.length - 1 && <br />}</Fragment>
                ))}
              </div>
              <div class="ingenuity__card-text">
                {slide.body.map((line, lineIndex) => (
                  <Fragment>{line}{lineIndex < slide.body.length - 1 && <br />}</Fragment>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
      <img class="ingenuity__bottom-image" src="/mca-allergencut/img/ingenuity-bottom-deco.webp" alt="" aria-hidden="true" loading="lazy" />
    </div>
  </div>
</section>

<style>
  /* ----------------------------------------
     Section & Screen Base
     ---------------------------------------- */

  /* ----------------------------------------
     Ingenuity Container
     ---------------------------------------- */
  .ingenuity {
    position: relative;
    width: 440px !important;
    height: 959px !important;
    overflow: hidden !important;
    background-color: var(--background-01);
    will-change: transform;
  }

  /* ----------------------------------------
     Header
     ---------------------------------------- */
  .ingenuity__header {
    position: absolute;
    top: 101px;
    left: 108px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 7px;
    width: 225px;
  }

  .ingenuity__label {
    align-self: stretch;
    color: var(--green-vivid);
    font-size: var(--font-size-s);
    font-weight: 700;
    letter-spacing: 0.70px;
    text-align: center;
  }

  .ingenuity__title {
    width: 317px;
    margin-left: -46px;
    margin-right: -46px;
    color: var(--brown-title-text);
    font-size: var(--font-size-title-xl);
    font-weight: 700;
    letter-spacing: 1.80px;
    text-align: center;
  }

  .ingenuity__subtitle {
    position: absolute;
    top: 185px;
    left: 50%;
    transform: translateX(-50%);
    width: 340px;
    color: var(--text-dark);
    font-family: var(--font-family);
    font-weight: 500;
    font-size: var(--font-size-s);
    letter-spacing: 0.7px;
    line-height: 1.7;
    text-align: center;
  }

  /* ----------------------------------------
     Background Cards (decorative)
     ---------------------------------------- */
  .ingenuity__bg-card {
    position: absolute;
    top: 268px;
    width: 326px;
    height: 326px;
    background-color: var(--white);
    border-radius: 10px;
    box-shadow: 3px 3px 5px var(--shadow-soft);
  }

  .ingenuity__bg-card--left {
    left: calc(50% - 509px);
  }

  .ingenuity__bg-card--right {
    left: calc(50% + 188px);
  }

  /* ----------------------------------------
     Slider Controls
     ---------------------------------------- */
  .ingenuity__slider {
    position: absolute;
    top: 621px;
    left: 57px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 326px;
  }

  /* ----------------------------------------
     Cards
     ---------------------------------------- */
  .ingenuity__card {
    position: absolute;
    top: 268px;
    left: 57px;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 10px;
    width: 326px;
    height: 326px;
    padding: 0 28px;
    background-color: var(--white);
    border-radius: 10px;
    box-shadow: 3px 3px 5px var(--shadow-soft);
  }

  .ingenuity__card-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 23px;
    width: 270px;
  }

  /* ----------------------------------------
     Card Images
     ---------------------------------------- */
  .ingenuity__card-image {
    width: 115px;
    height: 86px;
    object-fit: cover;
  }

  .ingenuity__card-image--pack {
    width: 204px;
    height: auto;
  }

  .ingenuity__card-image--nutrition {
    width: 115px;
    height: 86px;
    object-fit: contain;
  }

  /* ----------------------------------------
     Card Content & Typography
     ---------------------------------------- */
  .ingenuity__card-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 13px;
    width: 100%;
  }

  .ingenuity__card-heading {
    color: var(--text-dark);
    font-size: var(--font-size-xl);
    font-weight: 700;
    letter-spacing: 1.10px;
    line-height: 1.35;
    text-align: center;
  }

  .ingenuity__card-text {
    align-self: stretch;
    color: var(--text-dark);
    font-size: var(--font-size-s);
    font-weight: 500;
    letter-spacing: 0.80px;
    line-height: 1.7;
    text-align: center;
  }

  /* ----------------------------------------
     Bottom Decorative Image
     ---------------------------------------- */
  .ingenuity__bottom-image {
    position: absolute;
    top: 709px;
    left: calc(50% - 66px);
    width: 156px;
    height: 117px;
    object-fit: cover;
  }
</style>
