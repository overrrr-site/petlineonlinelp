---
---

<section class="section" style="background:var(--background-tan)" aria-labelledby="footer-cta-title">
  <div class="screen-wrapper">
    <div class="footercta screen">
      <div class="footercta__inner">
        <div class="footercta__stage">
          <div class="footercta__card" id="footer-cta">
            <div class="footercta__body">
              <div class="footercta__head">
                <div class="footercta__head-row">
                  <div class="footercta__deco footercta__deco--left">
                    <img class="footercta__deco-line footercta__deco-line--a" src="/img/line-2-7.svg" alt="" aria-hidden="true" />
                    <img class="footercta__deco-line footercta__deco-line--b" src="/img/line-3-7.svg" alt="" aria-hidden="true" />
                  </div>
                  <div class="footercta__head-text" id="footer-cta-title">お一人様1回限りの限定価格</div>
                  <div class="footercta__deco footercta__deco--right">
                    <img class="footercta__deco-line footercta__deco-line--c" src="/img/line-2-8.svg" alt="" aria-hidden="true" />
                    <img class="footercta__deco-line footercta__deco-line--d" src="/img/line-3-8.svg" alt="" aria-hidden="true" />
                  </div>
                </div>
                <img class="footercta__price" src="/img/vector-27.svg" alt="" aria-hidden="true" />
                <div class="footercta__price-unit">各</div>
              </div>

              <div class="footercta__cards">
                <div class="footercta__card-rice-wrap">
                  <div class="footercta__product footercta__product--rice">
                    <div class="footercta__product-row">
                      <div class="footercta__thumb-wrap"><img class="footercta__thumb" src="/img/u0311-3-1.png" alt="魚＆お米 2.5kg パッケージ" /></div>
                      <div class="footercta__product-info">
                        <p class="footercta__cname">
                          <span class="footercta__cname-main">魚＆お米</span><span class="footercta__cname-space">&nbsp;</span><span class="footercta__cname-sub">2.5kg</span>
                        </p>
                        <div class="footercta__tags">
                          <div class="footercta__tags-group">
                            <div class="footercta__tag"><div class="footercta__tag-text">子犬</div></div>
                            <div class="footercta__tag"><div class="footercta__tag-text">1歳~低脂肪</div></div>
                          </div>
                          <div class="footercta__tag footercta__tag--solo"><div class="footercta__tag-text">11歳から</div></div>
                        </div>
                        <a class="footercta__button" href="#" aria-label="1歳から 2.5kg で試す">
                          <div class="footercta__button-inner"><div class="footercta__button-text">1歳から（2.5kg）で試す</div></div>
                        </a>
                      </div>
                    </div>
                  </div>
                  <div class="footercta__recommend"><div class="footercta__recommend-text">迷ったらこちら</div></div>
                </div>
              </div>

              <div class="footercta__card-pea-wrap">
                <div class="footercta__product footercta__product--pea">
                  <div class="footercta__product-row">
                    <div class="footercta__thumb-wrap"><img class="footercta__thumb" src="/img/u0311-3.png" alt="魚＆えんどう豆たんぱく パッケージ" /></div>
                    <div class="footercta__product-info">
                      <h3 class="footercta__cname footercta__cname--pea">魚&amp;えんどう豆<br/>たんぱく<span class="footercta__cname-sub">&nbsp;2kg</span></h3>
                      <div class="footercta__tags-group footercta__tags-group--solo"><div class="footercta__tag"><div class="footercta__tag-text">11歳から</div></div></div>
                      <a class="footercta__button" href="#" aria-label="1歳から 2kg で試す">
                        <div class="footercta__button-inner"><div class="footercta__button-text">1歳から（2kg）で試す</div></div>
                      </a>
                    </div>
                  </div>
                </div>
              </div>

              <div class="footercta__note"><img class="footercta__note-icon" src="/img/frame-22.svg" alt="" aria-hidden="true" /><p class="footercta__note-text">送料当社負担<br/>お届けは1回のみ（自動継続なし）</p></div>
            </div>
          </div>
          <img class="footercta__badge" src="/img/1.png" alt="価格訴求の装飾" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .footercta {
    position: relative;
    width: 440px;
    height: 959px;
    background-color: var(--background-tan);
    overflow: hidden;
  }

  .footercta__inner {
    position: relative;
    width: 413px;
    height: 742px;
    top: 60px;
    left: 13px;
    display: flex;
    justify-content: center;
  }

  .footercta__stage {
    width: 413px;
    height: 742.17px;
    position: relative;
  }

  .footercta__card {
    display: flex;
    flex-direction: column;
    width: 413px;
    align-items: center;
    gap: 24px;
    padding: 20px 16px;
    position: absolute;
    top: 87px;
    left: calc(50% - 206px);
    background-color: var(--white);
    border-radius: 10px;
    box-shadow: 0px 4px 4px var(--shadow-strong);
  }

  .footercta__body {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    position: relative;
    flex: 0 0 auto;
  }

  /* Head */
  .footercta__head {
    position: relative;
    width: 338.01px;
    height: 124.17px;
  }

  .footercta__head-row {
    display: inline-flex;
    align-items: flex-start;
    justify-content: center;
    gap: 7px;
    position: absolute;
    top: 4px;
    left: 31px;
  }

  .footercta__deco {
    position: relative;
    width: 19.66px;
    height: 32.17px;
  }

  .footercta__deco--left {
    transform: rotate(180deg);
  }

  .footercta__deco-line {
    position: absolute;
  }

  .footercta__deco--left .footercta__deco-line--a {
    top: 1px;
    left: calc(50% - 11px);
    width: 18px;
    height: 32px;
    transform: rotate(-180deg);
  }

  .footercta__deco--left .footercta__deco-line--b {
    top: 4px;
    left: calc(50% - 2px);
    width: 11px;
    height: 14px;
    transform: rotate(-180deg);
  }

  .footercta__deco--right .footercta__deco-line--c {
    top: 0;
    left: calc(50% - 11px);
    width: 18px;
    height: 32px;
  }

  .footercta__deco--right .footercta__deco-line--d {
    top: 15px;
    left: calc(50% - 2px);
    width: 11px;
    height: 14px;
  }

  .footercta__head-text {
    position: relative;
    width: fit-content;
    margin-top: -1px;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--amber-brown);
    font-size: var(--font-size-l);
    letter-spacing: 0.32px;
    line-height: normal;
  }

  .footercta__price {
    position: absolute;
    width: 88.17%;
    height: 64.43%;
    top: 35.57%;
    left: 11.83%;
  }

  .footercta__price-unit {
    position: absolute;
    width: 10.06%;
    height: 22.55%;
    top: 70.87%;
    left: 0;
    font-family: var(--font-family);
    font-weight: 900;
    color: var(--orange);
    font-size: var(--font-size-title-l);
    letter-spacing: 1.33px;
    line-height: 27.6px;
    white-space: nowrap;
  }

  /* Cards */
  .footercta__cards {
    position: relative;
    width: 350px;
    height: 188px;
  }

  .footercta__card-rice-wrap {
    position: absolute;
    top: 12px;
    left: 0;
    width: 350px;
    height: 176px;
    display: flex;
  }

  .footercta__product--rice {
    display: flex;
    width: 350px;
    height: 176px;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: 12px;
    gap: 10px;
    position: relative;
    background-color: var(--white);
    border-radius: 10px;
    border: 2px solid var(--amber-brown);
    box-shadow: 3px 3px 5px var(--shadow-soft);
  }

  .footercta__product-row {
    display: flex;
    align-items: center;
    position: relative;
    align-self: stretch;
    width: 100%;
    flex: 0 0 auto;
  }

  .footercta__thumb-wrap {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px;
    position: relative;
    flex: 0 0 auto;
  }

  .footercta__thumb {
    position: relative;
    width: 72px;
    height: 128px;
    object-fit: contain;
  }

  .footercta__product-info {
    display: flex;
    flex-direction: column;
    width: 230.33px;
    align-items: flex-start;
    gap: 10px;
    padding: 0px 12px 12px;
    position: relative;
  }

  .footercta__cname {
    align-self: stretch;
    font-weight: 400;
    line-height: 24px;
    position: relative;
    margin-top: -1px;
    font-family: var(--font-family);
    color: var(--amber-brown);
    font-size: var(--font-size-product-title);
    letter-spacing: 1.2px;
  }

  .footercta__cname-main {
    font-weight: 700;
  }

  .footercta__cname-space {
    font-weight: 700;
    letter-spacing: 0.29px;
  }

  .footercta__cname-sub {
    font-weight: 500;
    font-size: var(--font-size-s);
    letter-spacing: 0.1px;
    line-height: 21px;
  }

  /* Tags */
  .footercta__tags {
    position: relative;
    width: 210.33px;
    height: 30px;
    margin-right: -4px;
  }

  .footercta__tags-group {
    position: absolute;
    top: 0;
    left: 0;
    width: 138px;
    height: 30px;
    display: flex;
    gap: 7px;
  }

  .footercta__tag {
    display: flex;
    width: 65.33px;
    height: 30px;
    position: relative;
    align-items: center;
    justify-content: center;
    gap: 5.98px;
    padding: 2.99px 13.15px 3.59px;
    border-radius: 59.79px;
    border: 1.2px solid var(--amber-brown);
  }

  .footercta__tag--solo {
    position: absolute;
    top: 0;
    left: 145px;
  }

  .footercta__tag-text {
    position: relative;
    width: fit-content;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--amber-brown);
    font-size: var(--font-size-xxs);
    text-align: center;
    letter-spacing: 0;
    line-height: 12.4px;
    white-space: nowrap;
  }

  /* Button */
  .footercta__button {
    position: relative;
    display: block;
    width: 204px;
    height: calc(44px / var(--scale));
    background-color: var(--orange);
    border-radius: 999px;
    box-shadow: 0px 4px 4px var(--shadow-strong);
  }

  .footercta__button-inner {
    position: relative;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footercta__button-text {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    width: 100%;
    font-family: var(--font-family);
    font-weight: 900;
    color: var(--white);
    font-size: calc(var(--font-size-l) / var(--scale));
    text-align: center;
    letter-spacing: 0;
    line-height: 1.2;
    white-space: nowrap;
  }

  /* Recommend badge */
  .footercta__recommend {
    position: absolute;
    top: -12px;
    left: 8px;
    width: 156px;
    height: 25px;
    background-color: var(--orange);
    border-radius: 100px;
  }

  .footercta__recommend-text {
    position: absolute;
    width: 80.14%;
    height: 85.71%;
    top: 0;
    left: 9.62%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-family);
    font-weight: 500;
    color: var(--white);
    font-size: var(--font-size-l);
    text-align: center;
    letter-spacing: 0.8px;
    line-height: 24px;
    white-space: nowrap;
  }

  /* Pea card */
  .footercta__card-pea-wrap {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    position: relative;
    flex: 0 0 auto;
  }

  .footercta__product--pea {
    display: flex;
    flex-direction: column;
    width: 350px;
    height: 176px;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px;
    position: relative;
    flex: 0 0 auto;
    background-color: var(--white);
    border-radius: 10px;
    border: 2px solid var(--amber-brown);
    box-shadow: 3px 3px 5px var(--shadow-soft);
  }

  .footercta__product--pea .footercta__product-row {
    display: inline-flex;
    align-items: center;
    position: relative;
    flex: 0 0 auto;
    width: auto;
    align-self: auto;
    margin-left: -0.17px;
    margin-right: -0.17px;
  }

  .footercta__cname--pea {
    align-self: stretch;
    font-weight: 700;
    line-height: 24px;
    position: relative;
    margin-top: -1px;
    font-family: var(--font-family);
    color: var(--amber-brown);
    font-size: var(--font-size-product-title);
    letter-spacing: 1.2px;
  }

  .footercta__tags-group--solo {
    position: relative;
    width: 65.33px;
    height: 30px;
    display: block;
  }

  .footercta__tags-group--solo .footercta__tag {
    left: 1px;
  }

  /* Note */
  .footercta__note {
    display: flex;
    width: 322.5px;
    align-items: center;
    justify-content: space-between;
    position: relative;
    flex: 0 0 auto;
  }

  .footercta__note-icon {
    position: relative;
    width: 21.38px;
  }

  .footercta__note-text {
    position: relative;
    width: fit-content;
    margin-top: -1px;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--text-dark);
    font-size: var(--font-size-subheading);
    letter-spacing: 0.9px;
    line-height: 31.5px;
  }

  /* Badge decoration */
  .footercta__badge {
    position: absolute;
    top: 0;
    left: calc(50% - 94px);
    width: 188px;
    height: 98px;
  }
</style>
