---
---

<a class="floating-cta" href="https://www.petlineonline.com/shop/r/r102011/" id="floating-cta" aria-label="今すぐ試す">
  <div class="floating-cta__bg"></div>
  <div class="floating-cta__inner">
    <img class="floating-cta__product" src="/mca-allergencut/img/u0311-3-2.png" alt="メディコート アドバンス アレルゲンカット パッケージ" />

    <div class="floating-cta__price-block">
      <div class="floating-cta__head">
        <span class="floating-cta__weight">2kg/2.5kg</span>
        <span class="floating-cta__badge">お一人様<br />1回限り</span>
      </div>
      <img class="floating-cta__price" src="/mca-allergencut/img/footer-price-800.png" alt="800円(税込)" />
    </div>

    <div class="floating-cta__action">
      <p class="floating-cta__note">送料当社負担/自動継続なし</p>
      <span class="floating-cta__btn">
        <span class="floating-cta__btn-text">今すぐ試す</span>
        <svg class="floating-cta__btn-arrow" width="8" height="14" viewBox="0 0 8 14" fill="none" aria-hidden="true">
          <path d="M1 1L6.5 7L1 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
    </div>
  </div>
</a>

<style>
  /* ==========================================
     Container — viewport-linked scale (grainfree base)
     ========================================== */
  .floating-cta {
    position: fixed;
    bottom: 0;
    left: 50%;
    width: 440px;
    transform: translate(-50%, 0) scale(var(--scale-w));
    transform-origin: 50% 100%;
    z-index: 1000;
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .floating-cta__bg {
    position: absolute;
    inset: 0;
    background-color: var(--floating-cta-bg);
    box-shadow: 0 -2px 8px var(--shadow-floating);
  }

  /* ==========================================
     Inner flow layout: package | price | action
     ========================================== */
  .floating-cta__inner {
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
    height: 90px;
    padding: 0 16px 0 14px;
  }

  /* パッケージはメニュー上端から少しはみ出すサイズに拡大 */
  .floating-cta__product {
    flex-shrink: 0;
    align-self: flex-end;
    width: 66px;
    height: 118px;
    margin-bottom: 2px;
    margin-right: 20px;
    object-fit: contain;
  }

  /* ==========================================
     Price block (center): weight + badge / big price
     ========================================== */
  .floating-cta__price-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    flex-shrink: 0;
  }

  .floating-cta__head {
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }

  .floating-cta__weight {
    color: var(--orange);
    font-family: var(--font-family);
    font-size: var(--font-size-subheading);
    font-weight: 900;
    letter-spacing: 0.6px;
    line-height: 1;
    white-space: nowrap;
  }

  .floating-cta__badge {
    padding: 1px 7px;
    border: 1px solid var(--orange);
    border-radius: 3px;
    color: var(--orange);
    font-family: var(--font-family);
    font-size: var(--font-size-xxs);
    font-weight: 700;
    letter-spacing: 0.2px;
    line-height: 1.25;
    text-align: center;
    white-space: nowrap;
  }

  .floating-cta__price {
    width: auto;
    height: 38px;
    margin-top: -2px;
    object-fit: contain;
  }

  /* ==========================================
     Action (right): note on top, CTA button below
     ========================================== */
  .floating-cta__action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin-left: auto;
    flex-shrink: 0;
  }

  .floating-cta__note {
    color: var(--text-dark);
    font-family: var(--font-family);
    font-size: var(--font-size-xxs);
    font-weight: 500;
    letter-spacing: 0.2px;
    line-height: 1.25;
    white-space: nowrap;
  }

  /* ==========================================
     CTA button — cta-glow / cta-shine
     ========================================== */
  .floating-cta__btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: calc(46px / var(--scale-w));
    padding: 0 22px;
    overflow: hidden;
    background-color: var(--orange);
    border-radius: 999px;
    animation: cta-glow 2s ease-in-out infinite;
  }

  .floating-cta:hover .floating-cta__btn {
    opacity: 0.9;
  }

  .floating-cta__btn::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent 0%, rgba(var(--white-rgb), 0.25) 50%, transparent 100%);
    animation: cta-shine 3s ease-in-out infinite;
    pointer-events: none;
  }

  .floating-cta__btn-text {
    color: var(--white);
    font-family: var(--font-family);
    font-size: calc(17px / var(--scale-w));
    font-weight: 900;
    letter-spacing: 0.7px;
    white-space: nowrap;
  }

  .floating-cta__btn-arrow {
    flex-shrink: 0;
    color: var(--white);
  }

  /* ==========================================
     Focus state
     ========================================== */
  .floating-cta:focus-visible {
    outline: 2px solid var(--lochmara);
    outline-offset: 2px;
  }

  /* ==========================================
     Keyframe animations
     ========================================== */
  @keyframes cta-glow {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(var(--orange-rgb), 0.4);
    }
    50% {
      box-shadow: 0 0 12px 4px rgba(var(--orange-rgb), 0.25);
    }
  }

  @keyframes cta-shine {
    0% {
      left: -100%;
    }
    20% {
      left: 100%;
    }
    100% {
      left: 100%;
    }
  }
</style>
