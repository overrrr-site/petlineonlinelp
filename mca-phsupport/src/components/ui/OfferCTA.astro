---
/**
 * OfferCTA — FV / type セクション共通のオファーCTA。
 * バッジ＋価格は元デザイン(cta-badge-price.svg = 旧CTA.svgからボタンを除いた版)を
 * そのまま画像で使用し、デザインを維持。「今すぐ試す」ボタンのみHTMLに分離して
 * 実要素化（glow/shine演出・クリック領域の明確化）。GTM契約は props でアンカーに転記。
 */
interface Props {
  lp: string;
  position: string;
  href?: string;
  ariaLabel?: string;
}
const {
  lp,
  position,
  href = '#footer-cta',
  ariaLabel = 'お一人様1回限りの限定価格 しっかり試せる2.5kgが800円 今すぐ試す',
} = Astro.props;
---

<a
  class="offer-cta"
  href={href}
  data-lp={lp}
  data-cta-position={position}
  data-cta-role="scroll_to_offer"
  aria-label={ariaLabel}
>
  <img
    class="offer-cta__badge-price"
    src="/mca-phsupport/img/cta-badge-price.svg"
    alt="お一人様1回限りの限定価格 しっかり試せる2.5kgが800円（税込）"
  />

  <span class="offer-cta__button">
    <span class="offer-cta__button-text">今すぐ試す</span>
    <svg class="offer-cta__button-arrow" width="9" height="15" viewBox="0 0 9 15" fill="none" aria-hidden="true">
      <path d="M1 1L7 7.5L1 14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>
</a>

<style>
  .offer-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
    text-decoration: none;
    color: inherit;
  }

  /* バッジ＋価格：元CTA.svgの上部（ボタン以外）をそのまま使用 */
  .offer-cta__badge-price {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ボタン：オレンジのピル＋glow/shine（元デザインの見た目を踏襲） */
  .offer-cta__button {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 247px;
    height: 56px;
    background-color: var(--orange);
    border-radius: 999px;
    box-shadow: 0px 4px 4px var(--shadow-strong);
    overflow: hidden;
    animation: cta-glow 2s ease-in-out infinite;
  }

  .offer-cta__button::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent 0%, rgba(var(--white-rgb), 0.25) 50%, transparent 100%);
    animation: cta-shine 3s ease-in-out infinite;
    pointer-events: none;
  }

  .offer-cta__button-text {
    font-family: var(--font-family);
    font-weight: 900;
    color: var(--white);
    font-size: var(--font-size-cta);
    letter-spacing: 1.09px;
  }

  .offer-cta__button-arrow {
    color: var(--white);
    flex-shrink: 0;
  }
</style>
