---
---

<section class="section" style="background:var(--background-tan)" aria-label="商品紹介">
  <div class="screen-wrapper">
    <div class="product screen">
      <div class="product__inner">
        <img class="product__photo" src="/mca-phsupport/img/adobestock-292120451-2.webp" alt="犬の写真" />
        <div class="product__card" aria-hidden="true"></div>
        <div class="product__age product__age--left"><span class="product__age-text">1歳から</span></div>
        <div class="product__age product__age--right"><span class="product__age-text">11歳から</span></div>
        <img class="product__package product__package--left" src="/mca-phsupport/img/u0311-1.webp" alt="1歳から 2.5kg パッケージ" />
        <img class="product__package product__package--right" src="/mca-phsupport/img/u0311-2.webp" alt="11歳から 2.5kg パッケージ" />
        <p class="product__brand">メディコートアドバンス<br />尿石ケア pHサポート</p>
        <div class="product__underline" aria-hidden="true"></div>
        <img class="product__gf-icon" src="/mca-phsupport/img/gf-c-f-2.webp" alt="ドライフードの粒" />

        <div class="product__heading">
          <div class="product__heading-group">
            <div class="product__heading-lines">
              <p class="product__heading-line product__heading-line--top">毎日のごはんだから、</p>
              <p class="product__heading-line product__heading-line--bottom">ミネラルバランスで選ぶ。</p>
            </div>
          </div>
          <img class="product__heading-deco product__heading-deco--outer" src="/mca-phsupport/img/group-5-1.webp" alt="" aria-hidden="true" />
        </div>

        <div class="product__cta" id="cta">
          <div class="product__cta-badge">
            <div class="product__cta-badge-text">お一人様1回限りの限定価格</div>
          </div>
          <p class="product__cta-price">しっかり試せる2.5kgが800円</p>
          <a class="product__cta-button" href="#footer-cta" aria-label="今すぐ試す">
            <div class="product__cta-button-bg" aria-hidden="true"></div>
            <img class="product__cta-button-arrow" src="/mca-phsupport/img/vector-1-6.svg" alt="" aria-hidden="true" />
            <div class="product__cta-button-text">今すぐ試す</div>
          </a>
          <p class="product__cta-micro">お届けは1回のみ。自動継続なし。</p>
        </div>

        <p class="product__desc">下部尿路の健康維持に配慮した、毎日の食事管理フード。<br/>愛犬の年齢に合わせて選べます。</p>
      </div>
    </div>
  </div>
</section>

<style>
  .product {
    position: relative;
    width: 440px;
    height: 959px;
    background-color: var(--background-tan);
    overflow: hidden;
  }

  .product__inner {
    position: relative;
    top: 37px;
    left: 24px;
    width: 402px;
    height: 780px;
    /* フッター(約120px)上の領域で上下を均等化（上に詰める） */
    transform: translateY(-26px);
  }

  .product__photo {
    position: absolute;
    top: 83px;
    left: 133px;
    width: 117px;
    height: 151px;
    object-fit: cover;
  }

  .product__card {
    position: absolute;
    top: 204px;
    left: calc(50% - 201px);
    width: 393px;
    height: 562px;
    background-color: var(--white);
    border-radius: 10px;
    box-shadow: 3px 3px 5px var(--shadow-soft);
  }

  /* 年齢バッジ（肉球の土台＋文字）。パッケージ下隅に配置 */
  .product__age {
    position: absolute;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    background-repeat: no-repeat;
    background-position: center;
    background-size: contain;
  }

  .product__age-text {
    font-family: var(--font-family);
    font-weight: 700;
    font-size: var(--font-size-xs);
    letter-spacing: -0.3px;
  }

  .product__age--left {
    top: 532px;
    left: 6px;
    width: 64px;
    height: 64px;
    background-image: url(/mca-phsupport/img/age-paw-teal.webp);
  }

  .product__age--left .product__age-text {
    color: var(--teal);
    margin-top: 12px;
    margin-left: 0;
  }

  .product__age--right {
    top: 530px;
    left: 320px;
    width: 70px;
    height: 67px;
    background-image: url(/mca-phsupport/img/age-paw-pink.webp);
  }

  .product__age--right .product__age-text {
    color: var(--cerise);
    margin-top: 8px;
    margin-left: 8px;
  }

  .product__package {
    position: absolute;
    width: 110px;
    height: 197px;
    object-fit: contain;
  }

  .product__package--left {
    top: 388px;
    left: 72px;
  }

  .product__package--right {
    top: 387px;
    left: 215px;
  }

  .product__brand {
    position: absolute;
    top: 234px;
    left: calc(50% - 136px);
    font-family: var(--font-family);
    font-weight: 900;
    color: var(--brown-amber);
    font-size: var(--font-size-product-brand);
    text-align: center;
    letter-spacing: -1.25px;
    line-height: 32px;
  }

  .product__desc {
    position: absolute;
    top: 332px;
    left: calc(50% - 187px);
    width: 374px;
    font-family: var(--font-family);
    font-weight: 500;
    color: var(--brown-amber);
    font-size: var(--font-size-s);
    letter-spacing: -0.2px;
    text-align: center;
    line-height: 1.7;
  }

  .product__underline {
    position: absolute;
    top: 300px;
    left: calc(50% - 141px);
    width: 282px;
    height: 26px;
    background-image: url(/mca-phsupport/img/vector-11-amber.svg);
    background-size: 100% 100%;
  }

  .product__gf-icon {
    position: absolute;
    top: 276px;
    left: 306px;
    width: 73px;
    height: 50px;
    object-fit: cover;
  }

  .product__heading {
    position: absolute;
    width: 337px;
    height: 73px;
    top: 0;
    left: 27px;
  }

  .product__heading-group {
    position: absolute;
    width: 337px;
    height: 73px;
    top: 0;
    left: 0;
  }

  .product__heading-lines {
    position: absolute;
    top: 0;
    left: 0;
    width: 337px;
    height: 72px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .product__heading-line {
    width: auto;
    height: 36px;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--white);
    font-size: var(--font-size-heading-line);
    letter-spacing: 0;
    line-height: 36px;
    text-align: center;
    white-space: nowrap;
  }

  .product__heading-line--bottom {
    margin-left: 0;
  }

  .product__heading-deco--inner {
    position: absolute;
    width: 337px;
    height: 44px;
    top: 29px;
    left: 0;
  }

  .product__heading-deco--outer {
    position: absolute;
    width: 392px;
    max-width: none;
    height: 53px;
    top: 20px;
    left: -28px;
  }

  .product__cta {
    position: absolute;
    top: 605px;
    left: 75px;
    width: 241px;
    height: 141px;
  }

  .product__cta-badge {
    display: flex;
    width: 69.71%;
    height: 18.44%;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 1px 12px;
    position: absolute;
    top: 0;
    left: 15.15%;
    border: 1px solid;
    border-color: var(--orange);
  }

  .product__cta-badge-text {
    position: relative;
    width: fit-content;
    margin-left: -2px;
    margin-right: -2px;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--orange);
    font-size: var(--font-size-xs);
    letter-spacing: -0.12px;
    line-height: 18px;
    white-space: nowrap;
  }

  .product__cta-price {
    position: absolute;
    width: 100%;
    height: 16.31%;
    top: 24.11%;
    left: 0;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--text-dark);
    font-size: var(--font-size-l);
    text-align: center;
    letter-spacing: 0.8px;
    line-height: normal;
  }

  .product__cta-button {
    position: absolute;
    width: 243px;
    height: 56px;
    top: 65px;
    left: 0;
  }

  .product__cta-button-bg {
    width: 99.18%;
    background-color: var(--orange);
    border-radius: 999px;
    box-shadow: 0px 4px 4px var(--shadow-strong);
    overflow: hidden;
    position: absolute;
    height: 100%;
    top: 0;
    left: 0;
    animation: cta-glow 2s ease-in-out infinite;
  }

  .product__cta-button-bg::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent 0%, rgba(var(--white-rgb), 0.25) 50%, transparent 100%);
    animation: cta-shine 3s ease-in-out infinite;
    pointer-events: none;
  }

  .product__cta-button-arrow {
    position: absolute;
    width: 7.5%;
    height: 34%;
    top: 33%;
    left: 71.5%;
    object-fit: contain;
  }

  @keyframes cta-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(var(--orange-rgb), 0.4); }
    50%      { box-shadow: 0 0 12px 4px rgba(var(--orange-rgb), 0.25); }
  }

  @keyframes cta-shine {
    0%   { left: -100%; }
    20%  { left: 100%; }
    100% { left: 100%; }
  }

  .product__cta-button-text {
    position: absolute;
    width: 46.09%;
    height: 55.36%;
    top: 17.65%;
    left: 24.75%;
    font-family: var(--font-family);
    font-weight: 900;
    color: var(--white);
    font-size: var(--font-size-cta);
    letter-spacing: 1.07px;
    line-height: normal;
  }

  .product__cta-micro {
    position: absolute;
    width: 86.62%;
    height: 14.18%;
    top: 85.82%;
    left: 7.05%;
    font-family: var(--font-family);
    font-weight: 700;
    color: var(--amber-brown);
    font-size: var(--font-size-xs);
    text-align: center;
    letter-spacing: 0;
    line-height: 19.2px;
  }

  .product__weight {
    position: absolute;
    width: 66px;
    height: 66px;
    object-fit: contain;
  }

  .product__weight--left {
    top: 532px;
    left: 0;
  }

  .product__weight--right {
    width: 84px;
    height: 80px;
    top: 525px;
    left: 311px;
  }
</style>
